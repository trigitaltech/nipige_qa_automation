BROWSER=chrome

# These timeouts are set in minutes
TEST_TIMEOUT=20
BROWSER_LAUNCH_TIMEOUT=0
ACTION_TIMEOUT=1
NAVIGATION_TIMEOUT=2

# Execution configurations
RETRIES=0
PARALLEL_THREAD=3 # Number of parallel workers/threads for running different spec files concurrently


# Test application configurations
BASE_URL=http://advantageonlineshopping.com

# Role-based company credentials (read by src/framework/config/Credentials.ts)
# NEVER commit real values — keep them in .env only.
ADMIN_EMAIL=
ADMIN_PASSWORD=
BULK_PROMOTION_TENANT_EMAIL=
BULK_PROMOTION_TENANT_PASSWORD=
TENANT_EMAIL=
TENANT_PASSWORD=
TENANT_ID=
SELLER_EMAIL=
SELLER_PASSWORD=
DELIVERY_EMAIL=
DELIVERY_PASSWORD=
USER_EMAIL=
USER_PASSWORD=

# API configurations
SOAP_API_BASE_URL=http://www.advantageonlineshopping.com:80
REST_API_BASE_URL=https://fakestoreapi.com

# DB configurations
DB_CONFIG=Server=localhost,1433;Database=AutomationDB;User Id=SA;Password=<password>

# Link to JIRA or any such tool for reporting
LINK=https://github.com/microsoft/playwright/issues/

# FreshCart storefront credentials (used by FreshCartServiceTicketTest)
FRESHCART_URL=https://freshcart-usa.nipige.com
FRESHCART_EMAIL=
FRESHCART_PASSWORD=

# Name of the test that needs to run locally
TEST_NAME=LoginTest
