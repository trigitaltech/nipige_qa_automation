BROWSER=chrome

# These timeouts are set in minutes
TEST_TIMEOUT=20
BROWSER_LAUNCH_TIMEOUT=0
ACTION_TIMEOUT=1
NAVIGATION_TIMEOUT=2

# Execution configurations
RETRIES=0
PARALLEL_THREAD=1

# Nipige application URL (e.g. https://your-nipige-instance.com)
BASE_URL=

# Role-based credentials (read by src/framework/config/Credentials.ts)
# NEVER commit real values — keep them in .env only.
SELLER_EMAIL=
SELLER_PASSWORD=
SELLER_TENANT=

# Link to issue tracker for Allure reporting
LINK=https://github.com/microsoft/playwright/issues/

# Name of the test file to run locally (without .spec.ts)
TEST_NAME=LoginTest
